# All optional. The site works without any of these, but they remove
# GitHub API rate limits and enable instant cache invalidation.

# GitHub personal access token (no scopes needed, repo is public) — raises
# the contents/tree API rate limit from 60/hr to 5000/hr per source IP.
GITHUB_TOKEN=

# Shared secret for POST /api/revalidate?secret=... (simple manual/cron trigger).
# Use a long random value, e.g. `openssl rand -hex 32` — this guards a real
# (rate-limited) endpoint, not a placeholder.
REVALIDATE_SECRET=

# Set this on the GitHub webhook (Settings > Webhooks > push event, content
# type application/json) pointed at https://<your-domain>/api/revalidate.
# When set, the endpoint verifies the X-Hub-Signature-256 HMAC instead of
# requiring the shared secret above.
GITHUB_WEBHOOK_SECRET=
